
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user's sustainability journey.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "ecoScore": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ImpactLog": {
      "title": "Impact Log",
      "description": "A record of a consumption audit and its carbon impact.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "emissions": { "type": "number" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "validationStatus": { "type": "string", "enum": ["verified", "mismatch", "insufficient_data"] },
        "auditData": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User specific sustainability profile."
    },
    "/users/{userId}/impact_logs/{logId}": {
      "schema": "ImpactLog",
      "description": "Collection of consumption audits for a user."
    }
  }
}
